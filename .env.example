# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/spotify/callback/

# Genius (optional, fallback lyrics provider) — https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# Ollama (optional, lyric embeddings) — use host.docker.internal in Docker
OLLAMA_URL=http://localhost:11434

# Django (generate a secure value for production)
# SECRET_KEY=
